<!DOCTYPE html>
<html lang="en">
<head>
    {{> head}}
</head>
<body>
    {{> header}}

    <!-- Hero Section -->
    <section class="hero">
        <video class="hero-video" autoplay muted loop playsinline>
            <source src="pexels-7147203-discussion.mp4?v=5" type="video/mp4">
        </video>
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <h1>{{hero.title}}</h1>
            <p class="hero-lead">{{hero.lead}}</p>
            <div class="hero-cta">
                <a href="tel:{{global.phone_link}}" class="btn btn-primary btn-large hero-btn-phone">
                    <svg class="hero-btn-phone-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>
                    </svg>
                    <span class="hero-btn-phone-text">
                        <span class="hero-btn-phone-eyebrow">{{hero.cta_phone_label}}</span>
                        <span class="hero-btn-phone-number">{{global.phone_display}}</span>
                    </span>
                </a>
                <a href="contact.html?service=quote" class="btn btn-secondary btn-large">{{hero.cta_quote_label}}</a>
            </div>
        </div>
    </section>

    <!-- Who we serve -->
    <section class="section" style="background-color: var(--bg-light);">
        <div class="container">
            <div class="section-title">
                <h2>{{who_we_serve.title}}</h2>
                <p>{{{who_we_serve.intro_1}}}</p>
                <p>{{{who_we_serve.intro_2}}}</p>
            </div>
            <div class="grid grid-2 cards-equal-row">
                <div class="card">
                    <h3>{{who_we_serve.audiences_title}}</h3>
                    <p>{{who_we_serve.audiences_intro}}</p>
                    <ul style="margin-top: 0.75rem; padding-left: 1.25rem; color: var(--text-light); line-height: 1.6;">
                        {{#each who_we_serve.audiences_list}}
                        <li>{{this}}</li>
                        {{/each}}
                    </ul>
                    <p style="margin-top: 1rem;">{{who_we_serve.audiences_footnote}}</p>
                </div>
                <div class="card">
                    <h3>{{who_we_serve.cultural_title}}</h3>
                    <p>{{who_we_serve.cultural_p1}}</p>
                    <p style="margin-top: 1rem;">{{{who_we_serve.cultural_p2}}}</p>
                    <a href="{{who_we_serve.cultural_cta_href}}" class="btn btn-secondary mt-2">{{who_we_serve.cultural_cta_label}}</a>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section class="section how-it-works">
        <div class="container">
            <div class="section-title">
                <h2>{{how_it_works.title}}</h2>
                <p>{{how_it_works.intro}}</p>
            </div>
            <div class="grid grid-3">
                {{#each how_it_works.steps}}
                <div class="step">
                    <div class="step-number">{{number}}</div>
                    <h3>{{title}}</h3>
                    <p>{{description}}</p>
                </div>
                {{/each}}
            </div>
        </div>
    </section>

    <!-- Trusted Partners Section -->
    {{#if partners.items.length}}
    <section class="section trusted-partners">
        <div class="container">
            <div class="section-title">
                <h2>{{partners.title}}</h2>
                <p>{{partners.intro}}</p>
            </div>
            <div class="partners-grid">
                {{#each partners.items}}
                <a class="partner-card" href="{{url}}" target="_blank" rel="noopener noreferrer" aria-label="Visit {{name}} (opens in new tab)">
                    {{#if logo}}
                    <div class="partner-logo-wrap">
                        <img src="{{logo}}" alt="{{name}} logo" class="partner-logo" loading="lazy">
                    </div>
                    {{/if}}
                    <div class="partner-info">
                        <h3 class="partner-name">{{name}}</h3>
                        {{#if description}}
                        <p class="partner-description">{{description}}</p>
                        {{/if}}
                        <span class="partner-link" aria-hidden="true">Visit website &rarr;</span>
                    </div>
                </a>
                {{/each}}
            </div>
        </div>
    </section>
    {{/if}}

    <!-- Services Preview Section -->
    <section class="section" style="background-color: var(--bg-light);">
        <div class="container">
            <div class="section-title">
                <h2>{{services_preview.title}}</h2>
                <p>{{services_preview.intro}}</p>
            </div>
            <div class="grid grid-3 cards-equal-row services-cards">
                {{#each services_preview.items}}
                <div class="card service-card">
                    {{#if image}}
                    <div class="card-photo">
                        <img src="{{image}}" alt="{{image_alt}}" loading="lazy">
                    </div>
                    {{/if}}
                    <div class="card-body">
                        <h3>{{title}}</h3>
                        <p>{{description}}</p>
                        <a href="{{link_href}}" class="btn btn-secondary">{{link_label}}</a>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>

    <!-- Service Areas Section -->
    <section class="section service-areas">
        <div class="container">
            <div class="section-title">
                <h2>{{service_areas.title}}</h2>
                <p>{{service_areas.intro}}</p>
            </div>
            <div class="grid grid-2 areas-grid">
                {{#each service_areas.items}}
                <article class="area-card area-card--editorial">
                    <span class="area-card-eyebrow">{{#if @first}}On-site{{else}}Anywhere{{/if}}</span>
                    <h3 class="area-card-title">{{title}}</h3>
                    <p class="area-card-description">{{description}}</p>
                </article>
                {{/each}}
            </div>
        </div>
    </section>

    {{> footer}}

    {{> scripts}}
</body>
</html>
